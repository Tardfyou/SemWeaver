# Copy values into your shell environment or a private .env file.
# Do not commit real API keys.

# LLM provider: openai, deepseek, anthropic, or openai_compatible.
SEMWEEVER_LLM_PROVIDER=openai
SEMWEEVER_MODEL=gpt-4.1
SEMWEEVER_REVIEW_MODEL=gpt-4.1

# Set exactly one key for the selected provider.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# Only needed for openai_compatible.
OPENAI_BASE_URL=

# Optional tool paths.
LLVM_DIR=/usr/lib/llvm-18
CLANGXX=/usr/lib/llvm-18/bin/clang++
CLANGD=/usr/lib/llvm-18/bin/clangd
CODEQL=codeql
CHROMA_HOST=localhost
